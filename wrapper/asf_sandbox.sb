; ASF Hermes wrapper sandbox profile for macOS sandbox-exec.
; sandbox-exec is deprecated by Apple. This is a feasibility probe only.
; It is opt-in and intended only for synthetic test commands, not for a real user shell.
; The Hermes runtime is not sandboxed. This profile applies to tool subprocesses only.
; Network egress is OS-constrained to the ASF local proxy. The proxy enforces the
; domain allowlist for HTTP and HTTPS CONNECT traffic. Raw TCP egress is blocked.

(version 1)
(deny default)

; Run the requested process tree.
(allow process*)
(allow sysctl-read)
(allow mach-lookup)

; Deny all network first, then allow only the local ASF egress proxy.
(deny network*)
(allow network-outbound
  (remote tcp (string-append "localhost:" (param "PROXY_PORT"))))

; Reads are intentionally broad so shells, the dynamic loader, locales, Python and Homebrew
; tools can start. Reads are NOT confined by this profile: (allow file-read*) permits broad
; filesystem reads subject only to normal macOS permissions/TCC. The previous Hermes plugin
; path allowlist gate was removed, and this profile does not consume a READ_ALLOW parameter.
; Seatbelt enforcement here is limited to write confinement under WORKDIR and proxy-only
; network egress for these terminal/execute_code subprocesses.
(allow file-read*)

; Minimal device access for stdio and process startup.
(allow file-read-data file-write-data
  (literal "/dev/null")
  (literal "/dev/zero")
  (literal "/dev/random")
  (literal "/dev/urandom"))

; The only writable filesystem area is the caller supplied workdir.
(allow file-write* (subpath (param "WORKDIR")))

; ASF Hermes wrapper sandbox profile for macOS sandbox-exec.
; sandbox-exec is deprecated by Apple. This is a feasibility probe only.
; It is opt-in and intended only for synthetic test commands, not for a real user shell.
; Ring model MVP: read access is limited to system/runtime paths, WORKDIR, and READ_ALLOW.
; Network remains denied at OS level. Domain allowlist is enforced in ASF pre-tool policy,
; not by Seatbelt, because sandbox-exec cannot filter by DNS domain.

(version 1)
(deny default)

; Run the requested process tree, but deny network explicitly below.
(allow process*)
(allow sysctl-read)
(allow mach-lookup)
(deny network*)

; Allow reads broadly so shells, dynamic loader, locales, Python and Homebrew tools can start.
; Ring 1 readable path policy is enforced before execution by the ASF Hermes plugin via
; ASF_HERMES_PATH_ALLOW. Seatbelt still enforces write confinement and network denial.
(allow file-read*)

; Minimal device access for stdio and process startup.
(allow file-read-data file-write-data
  (literal "/dev/null")
  (literal "/dev/zero")
  (literal "/dev/random")
  (literal "/dev/urandom"))

; The only writable filesystem area is the caller supplied workdir.
(allow file-write* (subpath (param "WORKDIR")))
